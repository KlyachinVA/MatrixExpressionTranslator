Rule 10    expression -> SCALAR LPAREN expression RPAREN
Rule 11    expression -> INVERSE expression
Rule 12    expression -> MATRIX
Rule 13    expression -> SCALAR
Rule 14    expression -> NUMBER
Rule 15    expression -> VECTOR

